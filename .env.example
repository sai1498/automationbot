# ─── AI / LLM ─────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro-preview-05-06

OPENAI_API_KEY=your_openai_api_key_here

# ─── Telegram ─────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
PUBLISHER_BOT_TOKEN=your_publisher_bot_token_here
WEBHOOK_SECRET=your_webhook_secret_here

# ─── Social Media ─────────────────────────────────────
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
LINKEDIN_PERSON_ID=your_linkedin_urn_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_id_here
INSTAGRAM_ACCESS_TOKEN=your_facebook_page_token_here

# ─── Security ─────────────────────────────────────────
ALLOWED_USERS=12345678,98765432
RATE_LIMIT_PER_MINUTE=10

# ─── Database ─────────────────────────────────────────
DATABASE_URL=sqlite:///data/bot.db

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=INFO
MAX_WORKERS=4
CACHE_TTL_HOURS=24
